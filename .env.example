# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dramatis

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:6767

# Storage (S3/R2/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Public URL for browser access (defaults to S3_ENDPOINT if not set)
S3_PUBLIC_URL=http://localhost:9000
# Buckets - created by docker-compose minio-setup
S3_BUCKET_HEADSHOTS=headshots
S3_BUCKET_VIDEOS=videos
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_TEMP=temp

# Document Encryption
DOCUMENT_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@dramatis-hq.com

# Redis (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379

# Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@dramatis-hq.com

# Monitoring & Error Tracking (Sentry)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=dramatis-hq
SENTRY_AUTH_TOKEN=sntrys_xxx

# Logging
LOG_LEVEL=info

# Analytics (optional, privacy-respecting)
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=dramatis-hq.com

# App Version (for release tracking)
NEXT_PUBLIC_APP_VERSION=1.0.0

# Pusher (Real-time WebSocket)
PUSHER_APP_ID=your-pusher-app-id
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
NEXT_PUBLIC_PUSHER_CLUSTER=us2
